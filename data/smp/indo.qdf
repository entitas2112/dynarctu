  - Text: (1) - (2) - (3) - (4) - (5)
  - Text: (3) - (2) - (1) - (4) - (5)
  - Text: (3) - (1) - (2) - (5) - (4)
  - Text: (2) - (1) - (4) - (5) - (3)
